{
  "name": "restful-toolkit",
  "displayName": "RestfulToolkit",
  "description": "VS Code extension for searching and navigating RESTful API endpoints in Java/Kotlin Spring and JAX-RS projects",
  "version": "0.0.4",
  "publisher": "kiturone",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "java",
    "kotlin",
    "spring",
    "jax-rs",
    "rest",
    "restful",
    "api",
    "endpoints",
    "search"
  ],
  "activationEvents": [
    "onLanguage:java",
    "onLanguage:kotlin",
    "workspaceContains:**/*.java",
    "workspaceContains:**/*.kt"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "restfulToolkit.searchEndpoints",
        "title": "%command.searchEndpoints.title%",
        "category": "RestfulToolkit"
      },
      {
        "command": "restfulToolkit.refreshEndpoints",
        "title": "%command.refreshEndpoints.title%",
        "category": "RestfulToolkit"
      },
      {
        "command": "restfulToolkit.createProjectConfig",
        "title": "%command.createProjectConfig.title%",
        "category": "RestfulToolkit"
      },
      {
        "command": "restfulToolkit.copyEndpointParameters",
        "title": "%command.copyEndpointParameters.title%",
        "category": "RestfulToolkit"
      },
      {
        "command": "restfulToolkit.copyUrl",
        "title": "%command.copyUrl.title%",
        "category": "RestfulToolkit"
      },
      {
        "command": "restfulToolkit.copyCurl",
        "title": "%command.copyCurl.title%",
        "category": "RestfulToolkit"
      }
    ],
    "keybindings": [
      {
        "command": "restfulToolkit.searchEndpoints",
        "key": "ctrl+alt+n",
        "mac": "cmd+alt+n",
        "when": "editorTextFocus"
      },
      {
        "command": "restfulToolkit.searchEndpoints",
        "key": "ctrl+\\",
        "mac": "cmd+\\",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "RestfulToolkit",
      "properties": {
        "restfulToolkit.scanPaths": {
          "type": "array",
          "default": [
            "**/src/main/java/**/*.java",
            "**/src/main/kotlin/**/*.kt"
          ],
          "description": "Glob patterns for scanning Java/Kotlin files. Automatically supports single-module and multi-module Maven/Gradle projects. Can also be configured via .restful-toolkit.json in project root"
        },
        "restfulToolkit.excludePaths": {
          "type": "array",
          "default": [
            "**/src/test/**",
            "**/target/**",
            "**/build/**",
            "**/.gradle/**",
            "**/node_modules/**"
          ],
          "description": "Glob patterns to exclude from scanning. Can also be configured via .restful-toolkit.json"
        },
        "restfulToolkit.maxResults": {
          "type": "number",
          "default": 100,
          "description": "Maximum number of search results to display"
        },
        "restfulToolkit.copyNameFormat": {
          "type": "string",
          "enum": ["camelCase", "snake_case"],
          "default": "camelCase",
          "description": "Default name format for copied parameter names"
        },
        "restfulToolkit.baseUrl": {
          "type": "string",
          "default": "",
          "description": "Base URL for generated URLs and cURL commands (e.g., http://localhost:8080). Overrides auto-detected values."
        }
      }
    },
    "menus": {
      "editor/context": [
        {
          "command": "restfulToolkit.copyEndpointParameters",
          "when": "editorLangId =~ /java|kotlin/",
          "group": "1_copy@1"
        },
        {
          "command": "restfulToolkit.copyUrl",
          "when": "editorLangId =~ /java|kotlin/",
          "group": "1_copy@2"
        },
        {
          "command": "restfulToolkit.copyCurl",
          "when": "editorLangId =~ /java|kotlin/",
          "group": "1_copy@3"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./dist/test/runTest.js",
    "build": "webpack --mode production",
    "dev": "webpack --mode development --watch"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^6.4.1",
    "@typescript-eslint/parser": "^6.4.1",
    "eslint": "^8.47.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "ts-loader": "^9.4.4",
    "typescript": "^5.1.6",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tedburner/RestfulToolkit.git"
  },
  "bugs": {
    "url": "https://github.com/tedburner/RestfulToolkit/issues"
  },
  "homepage": "https://github.com/tedburner/RestfulToolkit#readme",
  "license": "MIT"
}
